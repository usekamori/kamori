{
  "name": "kamori",
  "private": true,
  "version": "1.0.0",
  "license": "Elastic-2.0",
  "description": "Kamori — self-hosted log ingestion and AI-queryable MCP interface",
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "test": "vitest run",
    "dev:server": "npm run dev --workspace=packages/ingest",
    "start:server": "npm run start --workspace=packages/ingest",
    "start:mcp": "npm run start --workspace=packages/mcp",
    "start:mcp:stdio": "npm run start:stdio --workspace=packages/mcp",
    "start:lt": "PORT=4040 SUBDOMAIN=kamori-ingest node localtunnel.js",
    "k6:smoke": "npm run k6:smoke --workspace=packages/load-tests",
    "k6:stress": "npm run k6:stress --workspace=packages/load-tests",
    "k6:mixed": "npm run k6:mixed --workspace=packages/load-tests",
    "k6:spike": "npm run k6:spike --workspace=packages/load-tests",
    "k6:stress:all": "npm run k6:stress:all --workspace=packages/load-tests"
  },
  "devDependencies": {
    "@types/node": "^25.0.3",
    "fastify": "^5.8.4",
    "localtunnel": "^2.0.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18",
    "zod": "^3.25.76"
  },
  "dependencies": {
    "@fastify/cors": "^10.1.0",
    "@fastify/helmet": "^13.0.2",
    "@fastify/rate-limit": "^10.3.0",
    "better-sqlite3": "^11.10.0",
    "pino-pretty": "^13.1.3"
  }
}
