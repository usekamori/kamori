    "k6:mixed": "k6 run scripts/mixed-under-load.js --env TEST_PROFILE=stress",
    "k6:spike": "k6 run scripts/spike-recovery.js --env TEST_PROFILE=stress",
    "k6:stress:all": "npm run k6:stress && npm run k6:mixed && npm run k6:spike"
